<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bento_card"
    android:padding="16dp"
    android:elevation="2dp"
    android:layout_marginBottom="16dp">

    <!-- Header: Avatar, Name, ID, Pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvInisial"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_avatar"
            android:gravity="center"
            android:text="BS"
            android:textColor="@color/on_surface"
            android:textStyle="bold"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">
            <TextView
                android:id="@+id/tvNamaPenyewa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Budi Santoso"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvIdTransaksi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: #OUT-1234"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:textAllCaps="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTenggatPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_form_input"
            android:backgroundTint="@color/error_container"
            android:textColor="@color/on_error_container"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Hari Ini"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Body: Tool Details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_form_input"
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/ivAlat"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_tenda" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical">
            <TextView
                android:id="@+id/tvNamaAlat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tenda Dome 4P Pro"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvDetailAlat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2x Item disewa"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Button -->
    <Button
        android:id="@+id/btnSelesaikan"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:backgroundTint="@color/primary_container"
        android:textColor="@color/on_primary"
        android:text="Selesaikan Sewa"
        android:textStyle="bold"
        android:textSize="13sp"
        app:cornerRadius="8dp" />

</LinearLayout>
